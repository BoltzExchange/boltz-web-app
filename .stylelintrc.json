{
    "extends": ["stylelint-config-recommended-scss"],
    "plugins": [
        "./stylelint-theme-parity.mjs",
        "stylelint-declaration-strict-value"
    ],
    "rules": {
        "boltz/theme-token-parity": true,
        "declaration-block-no-duplicate-custom-properties": true,
        "declaration-block-no-duplicate-properties": [
            true,
            { "ignore": ["consecutive-duplicates-with-different-values"] }
        ],
        "declaration-block-no-shorthand-property-overrides": true,
        "custom-property-no-missing-var-function": true,
        "custom-property-pattern": [
            "^(color|border-radius|quote|rescue|settings)-[a-z0-9-]+$",
            {
                "message": "Token names must use a known namespace prefix (color, border-radius, quote, rescue, settings) followed by kebab-case."
            }
        ],
        "scale-unlimited/declaration-strict-value": [
            ["/color$/"],
            {
                "ignoreValues": ["currentColor", "inherit", "transparent"]
            }
        ],
        "scss/at-extend-no-missing-placeholder": null
    }
}
