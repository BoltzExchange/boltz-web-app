{
    "name": "boltz-frontend",
    "version": "2.0.3",
    "description": "Boltz Exchange, Atomic Swaps, Web App",
    "scripts": {
        "start": "bun run regtest && vite",
        "test": "bun run regtest && vitest ./tests",
        "test:e2e": "bun run regtest && playwright test",
        "playwright:install": "playwright install --with-deps chromium",
        "dev": "vite",
        "preview": "vite preview",
        "build": "./build.py && vite build; cp dist/index.html dist/404.html",
        "build:regular": "bun run index-template-vars.mjs --regular && bun run build",
        "build:pro": "bun run index-template-vars.mjs --pro && bun run build",
        "check:html-template": "bun run index-template-vars.mjs --regular && bun run index-template-vars.mjs --pro",
        "build:docker": "docker build --build-arg NETWORK=mainnet . -o build -f build/Dockerfile && docker build --build-arg NETWORK=pro . -o build -f build/Dockerfile",
        "mainnet": "cp src/configs/mainnet.ts src/config.ts",
        "beta": "cp src/configs/beta.ts src/config.ts",
        "pro": "cp src/configs/pro.ts src/config.ts",
        "testnet": "cp src/configs/testnet.ts src/config.ts",
        "regtest": "cp src/configs/regtest.ts src/config.ts",
        "postinstall": "bun run regtest && bun run generate",
        "prettier": "bunx prettier src public tests e2e docs .github *.ts *.mjs *.json *.html README.md",
        "prettier:write": "bun run prettier -- --write",
        "prettier:check": "bun run prettier -- --check",
        "check": "bun run prettier:write && bun run lint -- --fix && bun run tsc",
        "tsc": "tsc",
        "lint": "eslint --max-warnings 0 --concurrency auto .",
        "changelog": "git-cliff -o CHANGELOG.md",
        "docs:dev": "vitepress dev docs",
        "docs:build": "vitepress build docs",
        "docs:preview": "vitepress preview docs",
        "generate:solana-oft": "codama run --all",
        "generate": "bun run generate:solana-oft",
        "optimize:assets": "bun run optimize-assets.mjs",
        "check:assets": "bun run check-assets.mjs"
    },
    "devDependencies": {
        "@codama/nodes-from-anchor": "^1.4.1",
        "@codama/renderers-js": "^2.1.0",
        "@eslint/js": "^9.39.2",
        "@playwright/test": "^1.59.1",
        "@solidjs/testing-library": "^0.8.10",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/user-event": "^14.6.1",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/node": "^25.6.0",
        "@webbtc/webln-types": "^3.0.0",
        "axios": "^1.15.0",
        "codama": "^1.6.0",
        "eslint": "^9.39.2",
        "eslint-plugin-solid": "^0.14.5",
        "git-cliff": "^2.12.0",
        "globals": "^17.5.0",
        "jsdom": "^29.0.2",
        "prettier": "^3.8.3",
        "sass-embedded": "^1.99.0",
        "svgo": "^4.0.1",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.2",
        "viem": "^2.47.18",
        "vite": "^8.0.8",
        "vite-plugin-node-polyfills": "^0.26.0",
        "vite-plugin-solid": "^2.11.12",
        "vite-plugin-wasm": "^3.6.0",
        "vitepress": "^1.6.4",
        "vitest": "^4.1.4"
    },
    "dependencies": {
        "@fontsource/noto-mono": "^5.2.5",
        "@fontsource/noto-sans": "^5.2.10",
        "@ledgerhq/hw-app-eth": "^7.6.2",
        "@ledgerhq/hw-transport-webhid": "^6.34.0",
        "@noble/curves": "^2.2.0",
        "@noble/hashes": "^2.2.0",
        "@reown/appkit": "^1.8.19",
        "@reown/appkit-adapter-ethers": "^1.8.19",
        "@reown/appkit-adapter-solana": "^1.8.19",
        "@reown/appkit-adapter-tron": "^1.8.19",
        "@metaplex-foundation/mpl-toolbox": "^0.10.0",
        "@metaplex-foundation/umi": "^1.5.1",
        "@metaplex-foundation/umi-bundle-defaults": "^1.5.1",
        "@metaplex-foundation/umi-signer-wallet-adapters": "^1.5.1",
        "@layerzerolabs/lz-solana-sdk-v2": "^3.0.168",
        "@scure/base": "^2.0.0",
        "@scure/bip32": "^2.0.1",
        "@scure/bip39": "^2.0.1",
        "@scure/btc-signer": "^2.0.1",
        "@solana/kit": "^6.8.0",
        "@solana/web3.js": "^1.98.4",
        "@solana/program-client-core": "^6.8.0",
        "@solid-primitives/i18n": "^2.2.1",
        "@solid-primitives/storage": "^4.3.4",
        "@solidjs/router": "^0.16.1",
        "@trezor/connect-web": "^9.7.2",
        "@tronweb3/tronwallet-adapter-metamask-tron": "1.0.1",
        "@tronweb3/tronwallet-adapter-tronlink": "1.1.13",
        "@vulpemventures/secp256k1-zkp": "^3.2.1",
        "bignumber.js": "^11.0.0",
        "bolt11": "^1.4.1",
        "bolt12-utils": "^0.1.1",
        "boltz-core": "^4.0.3",
        "buffer": "^6.0.3",
        "create-hmac": "^1.1.7",
        "ethers": "^6.16.0",
        "liquidjs-lib": "^6.0.2-liquid.37",
        "localforage": "^1.10.0",
        "loglevel": "^1.9.2",
        "qr-scanner": "^1.4.2",
        "qrcode": "^1.5.4",
        "solid-icons": "^1.2.0",
        "solid-js": "^1.9.12",
        "tronweb": "^6.2.2"
    }
}
