    "files": [
        "dist"
    ],
    "scripts": {
        "build": "rm -rf .tsbuildinfo dist/ && tsc",
        "dev": "tsc --watch",
        "tsc": "tsc --noEmit && tsc --noEmit -p tests/tsconfig.json && tsc --noEmit -p examples/tsconfig.json",
        "test": "vitest run",
        "check:lazy": "node scripts/check-eager-loads.mjs",
        "check:package": "node scripts/check-package-smoke.mjs",
        "prettier": "bunx prettier --cache src tests scripts *.json *.mjs",
        "prettier:write": "bun run prettier -- --write",
        "prettier:check": "bun run prettier -- --check",
        "lint": "eslint --max-warnings 0 --cache src scripts",
        "check": "bun run prettier:write && bun run lint -- --fix && bun run tsc",
        "generate:evm-abis": "bun run scripts/generate-evm-abis.ts",
        "generate:solana-oft": "codama run solana-oft",
        "generate:solana-cctp": "codama run solana-cctp --idl src/generated/solana-cctp-token-messenger-minter-v2-idl.json",
        "generate:fix-codama-imports": "bun run scripts/fix-codama-imports.ts",
        "generate": "bun run generate:evm-abis && bun run generate:solana-oft && bun run generate:solana-cctp && bun run generate:fix-codama-imports",
        "prepublishOnly": "bun run generate && bun run build"
    },
    "dependencies": {
        "@noble/hashes": "catalog:",
        "@scure/base": "catalog:"
    },
    "peerDependencies": {
        "@layerzerolabs/lz-solana-sdk-v2": "catalog:",
